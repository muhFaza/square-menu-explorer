# Copy this file to .env.local and replace the placeholders with Sandbox values.
# Never commit .env.local or paste the access token into source code, logs, or chat.

# Square Developer Console -> your application -> Sandbox -> Credentials
SQUARE_ACCESS_TOKEN=your_sandbox_access_token
SQUARE_ENVIRONMENT=sandbox

# Reserved for Square application metadata or a future OAuth flow.
# The read-only Catalog and Locations proxy uses SQUARE_ACCESS_TOKEN.
SQUARE_APPLICATION_ID=your_sandbox_application_id

# Square Developer Console -> your application -> Webhooks -> Subscriptions.
# Both are required only to enable the catalog cache-busting webhook listener;
# leave them unset to disable it. The notification URL must exactly match the
# subscription's endpoint (it is part of the HMAC signature payload).
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.example/api/webhooks/square

# Optional admin key that enables POST /api/admin/cache/invalidate to bust the
# catalog and locations caches on demand. Leave unset to disable the endpoint
# (it then returns 404 and does not advertise itself). Kept commented out so a
# verbatim copy of this file never enables the endpoint with a known value.
# Generate a strong value, for example with `openssl rand -hex 32`.
# ADMIN_API_KEY=

# Local development server port
PORT=3000